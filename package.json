{
  "name": "@lycolia/next-boilerplate",
  "version": "0.35.0",
  "description": "Next.js Static Site Generation boilerplate for TypeScript",
  "author": "Lycolia",
  "license": "MIT",
  "repository": {
    "type": "git",
    "url": "https://github.com/Lycolia/ts-next-boilerplate"
  },
  "scripts": {
    "dev": "cross-env NODE_OPTIONS='--inspect' next",
    "start": "next",
    "build": "next build --profile",
    "serve": "serve -p 3000 ./out",
    "test": "jest --watch",
    "fix": "biome format --write src/ && prettier --write *.md",
    "lint": "tsc --noEmit && biome lint src/",
    "headless-test": "pnpm lint && jest",
    "coverage": "jest --coverage",
    "storybook": "storybook dev -p 6006",
    "build-storybook": "storybook build",
    "postinstall": "git config core.hooksPath .git-hooks"
  },
  "devDependencies": {
    "@biomejs/biome": "2.4.13",
    "@chromatic-com/storybook": "^5.1.2",
    "@eslint/js": "^10.0.1",
    "@next/eslint-plugin-next": "^16.2.4",
    "@storybook/addon-a11y": "^10.3.6",
    "@storybook/addon-docs": "^10.3.6",
    "@storybook/addon-onboarding": "^10.3.6",
    "@storybook/addon-vitest": "^10.3.6",
    "@storybook/nextjs-vite": "^10.3.6",
    "@swc/cli": "^0.8.1",
    "@swc/core": "^1.15.32",
    "@swc/jest": "^0.2.39",
    "@testing-library/jest-dom": "^6.9.1",
    "@testing-library/react": "^16.3.2",
    "@types/jest": "^30.0.0",
    "@types/node": "^25.6.0",
    "@types/react": "^19.2.14",
    "@types/react-dom": "^19.2.3",
    "@types/react-test-renderer": "^19.1.0",
    "@vitest/browser-playwright": "^4.1.5",
    "@vitest/coverage-v8": "^4.1.5",
    "babel-loader": "^10.1.1",
    "cross-env": "^10.1.0",
    "identity-obj-proxy": "^3.0.0",
    "jest": "^30.3.0",
    "jest-environment-jsdom": "^30.3.0",
    "jest-watch-typeahead": "^3.0.1",
    "next": "^16.2.4",
    "playwright": "^1.59.1",
    "prettier": "^3.8.3",
    "react": "^19.2.5",
    "react-dom": "^19.2.5",
    "react-test-renderer": "^19.2.5",
    "sass": "^1.99.0",
    "storybook": "^10.3.6",
    "typescript": "^6.0.3",
    "vite": "^8.0.10",
    "@storybook/addon-links": "^10.3.6",
    "@testing-library/dom": "^10.4.1"
  }
}
